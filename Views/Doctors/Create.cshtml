@model CreateDoctorViewModel
@{
    ViewData["Title"] = "Add Doctor";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Add Doctor</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
</div>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Doctor Information</h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="FirstName" class="form-label"></label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="LastName" class="form-label"></label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Specialization" class="form-label"></label>
                    <input asp-for="Specialization" class="form-control" placeholder="e.g. Cardiology" />
                    <span asp-validation-for="Specialization" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Phone" class="form-label"></label>
                    <input asp-for="Phone" class="form-control" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Schedule</h5>
        </div>
        <div class="card-body">
            <div class="row g-3 mb-3 align-items-end">
                <div class="col-12 col-md-6">
                    <label class="form-label d-block mb-2">Working days</label>
                    <div class="d-flex flex-wrap gap-3">
                        @for (var i = 0; i < Model.Days.Count; i++)
                        {
                            <label class="form-check form-check-inline mb-0">
                                <input class="form-check-input" asp-for="Days[i].IsSelected" />
                                <span class="form-check-label">@Model.Days[i].DayOfWeek</span>
                                <input type="hidden" asp-for="Days[i].DayOfWeek" />
                            </label>
                        }
                    </div>
                </div>

                <div class="col-6 col-md-3">
                    <label asp-for="StartTime" class="form-label"></label>
                    <input asp-for="StartTime" type="time" class="form-control" />
                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>

                <div class="col-6 col-md-3">
                    <label asp-for="EndTime" class="form-label"></label>
                    <input asp-for="EndTime" type="time" class="form-control" />
                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>
            </div>

            <div class="text-muted small">
                Pick days (e.g. Mon/Sun) and one start/end time. Slots are generated automatically (30 minutes).
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

