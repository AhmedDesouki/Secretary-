@model DoctorIndexViewModel
@{
    ViewData["Title"] = "Doctors";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Doctors</h1>
    <a asp-action="Create" class="btn btn-primary">Add Doctor</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Specialization</th>
            <th>Clinic</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Schedule</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Doctors.Any())
        {
            foreach (var d in Model.Doctors)
            {
                <tr>
                    <td class="fw-semibold">@d.FullName</td>
                    <td>@d.Specialization</td>
                    <td>@d.ClinicName</td>
                    <td>@d.Phone</td>
                    <td>@d.Email</td>
                    <td class="text-muted">@d.ScheduleSummary</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">No doctors found.</td>
            </tr>
        }
        </tbody>
    </table>
</div>

